# Hungry Panda Configuration

# =============================================================================
# INSTAGRAM ACCOUNT SETTINGS
# =============================================================================

# Your Instagram handle (without @ symbol)
INSTAGRAM_USERNAME=your_instagram_username

# Instagram password (required for browser automation and DM MCP)
INSTAGRAM_PASSWORD=your_instagram_password

# Account type: personal, business, or creator
# - personal: Use with manual or browser posting methods
# - business/creator: Required for MCP (ig-mcp) and API methods
INSTAGRAM_ACCOUNT_TYPE=personal

# =============================================================================
# POSTING METHOD
# =============================================================================

# How to publish content to Instagram:
# - manual: Agent prepares content, you post via Instagram app (RECOMMENDED)
# - mcp: Uses Instagram MCP server via official Graph API (Business/Creator only)
# - api: Direct Instagram Graph API integration (legacy)
# - browser: Browser automation (legacy, higher ban risk)
POSTING_METHOD=manual

# =============================================================================
# MCP (Model Context Protocol) INTEGRATION
# =============================================================================

# Enable MCP integration for enhanced Instagram connectivity
ENABLE_MCP_INTEGRATION=false

# MCP server type:
# - ig-mcp: Official Instagram Graph API (requires Business/Creator account)
# - instagram_dm_mcp: Unofficial API for DMs and personal accounts
MCP_SERVER_TYPE=ig-mcp

# Path to MCP server script (if installed separately)
# Example: /path/to/ig-mcp/src/instagram_mcp_server.py
MCP_SERVER_PATH=

# Instagram Business Account ID (for MCP/Graph API)
# Get this from Facebook Graph API Explorer
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# =============================================================================
# INSTAGRAM API CREDENTIALS (For Business/Creator accounts)
# =============================================================================

# Facebook App credentials (required for MCP and API methods)
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret

# Long-lived access token (valid 60 days)
# Get from Facebook Graph API Explorer or OAuth flow
INSTAGRAM_ACCESS_TOKEN=your_access_token

# =============================================================================
# EXTERNAL API KEYS (Optional)
# =============================================================================

# OpenAI API key for enhanced AI caption generation
# Get from: https://platform.openai.com
OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# SERVER SETTINGS
# =============================================================================

HOST=0.0.0.0
PORT=8000
DEBUG=true

# =============================================================================
# SCHEDULER SETTINGS
# =============================================================================

# Enable automated scheduler for automatic posting
AUTO_SCHEDULER_ENABLED=false

# How often to check for scheduled posts (minutes)
CHECK_INTERVAL_MINUTES=5

# =============================================================================
# CONTENT SETTINGS
# =============================================================================

MAX_POSTS_PER_DAY=3
DEFAULT_TIMEZONE=local
CAPTION_LANGUAGE=en  # en, es, fr, etc.

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_PATH=./hungry_panda.db

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_COMPETITOR_TRACKING=true
ENABLE_AUTO_CAPTIONS=true
ENABLE_AUTO_HASHTAGS=true
ENABLE_ANALYTICS=true
